<?xml version="1.0" encoding="utf-8"?>
<Configuration>
	<Brightness>
		<Enable>true</Enable>
		<Level>15</Level>
		<!-- -255..255 -->
	</Brightness>
	<Rotation>
		<Enable>true</Enable>
		<MinAngle>-1</MinAngle>
		<!-- отрицательный = влево -->
		<MaxAngle>2</MaxAngle>
		<!-- положительный = вправо -->
	</Rotation>
	<Grayscale>
		<Enable>true</Enable>
	</Grayscale>
	<ImageQuality>
		<Dpi>150</Dpi>
		<!-- качество растеризации -->
		<JpegCompression>85</JpegCompression>
		<!-- 1-100 -->
	</ImageQuality>
</Configuration>